{
  "name": "@tigerabrodioss/sfxlib",
  "version": "0.0.0",
  "description": "Web-focused sound effect generator for TypeScript. Chainable, immutable. Built on Web Audio.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "vite build",
    "test": "vitest run --passWithNoTests",
    "test:unit": "vitest run --project unit --passWithNoTests",
    "test:browser": "vitest run --project browser --passWithNoTests",
    "test:watch": "vitest --passWithNoTests",
    "typecheck": "tsc -b --noEmit"
  },
  "keywords": [
    "audio",
    "sound",
    "sfx",
    "web-audio",
    "game-audio",
    "typescript"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/browser": "^4.1.4",
    "@vitest/browser-playwright": "^4.1.4",
    "playwright": "^1.50.0",
    "vite": "^8.0.8",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.4"
  }
}
