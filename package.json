{
  "name": "sfxlib-monorepo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "bun run --cwd packages/sfx build",
    "test": "bun run --cwd packages/sfx test",
    "test:unit": "bun run --cwd packages/sfx test:unit",
    "test:browser": "bun run --cwd packages/sfx test:browser",
    "tsc": "tsc -b",
    "lint": "eslint .",
    "format": "prettier --write \"packages/**/*.{ts,html,css,md}\" \"*.md\""
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.12",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "prettier": "^3.8.1",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.58.2"
  }
}
